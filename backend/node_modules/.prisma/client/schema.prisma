// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nama      String
  email     String   @unique
  password  String
  angkatan  String
  prodi     String   @default("Informatika")
  status    String   @default("Anggota") // Pengurus, Anggota, Alumni
  role      String   @default("user") // admin, user
  foto      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  newsAuthored   News[]
  registrations  Registration[]
  attendanceLogs AttendanceLog[]
  aspirations    Aspiration[]

  @@map("users")
}

model News {
  id         String    @id @default(uuid())
  judul      String
  slug       String    @unique
  konten     String
  ringkasan  String?
  thumbnail  String?
  kategori   String    @default("Umum") // Umum, Akademik, Kegiatan, Prestasi
  status     String    @default("draft") // draft, published
  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  tglPublish DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("news")
}

model Event {
  id           String    @id @default(uuid())
  judul        String
  slug         String    @unique
  deskripsi    String
  thumbnail    String?
  tanggal      DateTime
  tanggalAkhir DateTime?
  lokasi       String
  kuota        Int       @default(100)
  biaya        Int       @default(0)
  status       String    @default("upcoming") // upcoming, ongoing, done, cancelled
  kategori     String    @default("Kegiatan") // Kegiatan, Seminar, Workshop, Kompetisi
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  registrations Registration[]
  attendances   Attendance[]

  @@map("events")
}

model Registration {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tglDaftar   DateTime @default(now())
  statusHadir String   @default("registered") // registered, hadir, tidak_hadir
  createdAt   DateTime @default(now())

  // Relations
  certificate ECertificate?

  @@unique([eventId, userId])
  @@map("registrations")
}

model Attendance {
  id         String   @id @default(uuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  namaSesi   String // "Sesi Masuk", "Sesi Keluar"
  waktuBuka  DateTime
  waktuTutup DateTime
  kodeAbsen  String   @unique @default(uuid())
  createdAt  DateTime @default(now())

  // Relations
  logs AttendanceLog[]

  @@map("attendances")
}

model AttendanceLog {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  waktuAbsen   DateTime   @default(now())

  @@unique([attendanceId, userId])
  @@map("attendance_logs")
}

model ECertificate {
  id           String       @id @default(uuid())
  regId        String       @unique
  registration Registration @relation(fields: [regId], references: [id])
  fileUrl      String?
  nomorSertif  String       @unique @default(uuid())
  tglTerbit    DateTime     @default(now())

  @@map("e_certificates")
}

model Aspiration {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  kategori    String // Akademik, Kegiatan, Fasilitas, Lainnya
  isiAspirasi String
  isAnonymous Boolean  @default(false)
  status      String   @default("pending") // pending, reviewed, resolved
  responAdmin String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("aspirations")
}
